<!DOCTYPE html>
<html lang="en">
<head>
    <title>WhatsApp Web - Messages</title>
    {% load static %}
    <link rel="stylesheet" href="{% static 'styles.css' %}">
    <style>
        .conversation-preview {
            padding: 10px;
            border-bottom: 1px solid var(--border-light);
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .conversation-preview:hover {
            background-color: #f0f0f0;
        }
        .conversation-preview.active {
            background-color: #e8f0fe;
        }
        .chat-area {
            display: none;
            flex-direction: column;
            height: 100%;
        }
        .chat-area.active {
            display: flex;
        }
        .chat-messages {
            flex-grow: 1;
            overflow-y: auto;
            padding: 20px;
        }
        .chat-header {
            padding: 15px;
            border-bottom: 1px solid var(--border-light);
            background-color: #f8f9fa;
        }
        .no-chat-selected {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--text-secondary);
            font-size: 1.1em;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar with conversations list -->
        <aside class="sidebar" style="width: 30%; min-width: 300px; display: flex; flex-direction: column; height: 100%; border-right: 1px solid var(--border-light);">
            <div class="sidebar-header" style="padding: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light);">
                <h2 style="font-size: 1.1em; margin: 0;">Messages</h2>
                <a href="{% url 'new_message' %}" class="nav-link" style="padding: 6px;">
                    <span style="display: flex; align-items: center;">
                        <svg style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M12 5v14M5 12h14" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </span>
                </a>
            </div>

            <!-- Conversations List -->
            <div style="flex-grow: 1; overflow-y: auto;">
                {% for conversation in conversations %}
                    <div class="conversation-preview" onclick="showConversation('{{ conversation.user.id }}')">
                        <div style="font-weight: 500;">
                            {{ conversation.user.username }}
                        </div>
                        {% with last_message=conversation.messages|first %}
                            <div style="font-size: 0.9em; color: #666; margin-top: 4px;">
                                {{ last_message.content|truncatewords:5 }}
                            </div>
                            <div style="font-size: 0.8em; color: #888; margin-top: 4px;">
                                {{ last_message.timestamp|date:"M d, Y H:i" }}
                            </div>
                        {% endwith %}
                    </div>
                {% empty %}
                    <div style="text-align: center; padding: 20px; color: #666;">
                        No messages yet
                    </div>
                {% endfor %}
            </div>

            <!-- Logout -->
            <div style="padding: 10px; border-top: 1px solid var(--border-light);">
                <a href="{% url 'logout' %}" class="nav-link" style="padding: 6px; color: #dc3545;">
                    <span style="display: flex; align-items: center;">
                        <svg style="margin-right: 6px; width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        Logout
                    </span>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content" style="flex-grow: 1; display: flex; flex-direction: column; height: 100%;">
            <!-- Default State -->
            <div id="noChatSelected" class="no-chat-selected">
                Select a conversation to start messaging
            </div>

            <!-- Chat Area (Hidden by default) -->
            <div id="chatArea" class="chat-area">
                <div id="chatHeader" class="chat-header">
                    <!-- Conversation partner name will be inserted here -->
                </div>

                <div id="chatMessages" class="chat-messages">
                    <!-- Messages will be inserted here -->
                </div>

                <!-- Reply Form -->
                <div style="padding: 15px; border-top: 1px solid var(--border-light);">
                    <form id="replyForm" method="post" action="{% url 'new_message' %}" style="display: flex; gap: 10px;">
                        {% csrf_token %}
                        <input type="hidden" id="recipient_id" name="recipient" value="">
                        <textarea
                            name="content"
                            placeholder="Type a message"
                            style="flex-grow: 1; padding: 8px; border-radius: 4px;"
                            required
                        ></textarea>
                        <button type="submit" style="padding: 8px 16px;">Reply</button>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <script>
        async function showConversation(userId) {
            // Update active conversation
            document.querySelectorAll('.conversation-preview').forEach(el => {
                el.classList.remove('active');
            });
            event.currentTarget.classList.add('active');

            // Hide no-chat message and show chat area
            document.getElementById('noChatSelected').style.display = 'none';
            document.getElementById('chatArea').classList.add('active');

            // Update chat header
            document.getElementById('chatHeader').innerHTML = event.currentTarget.querySelector('div').textContent;

            // Set recipient for reply form
            document.getElementById('recipient_id').value = userId;

            try {
                // Fetch conversation messages from the server
                const response = await fetch(`/conversation/${userId}/`);
                const data = await response.json();

                if (data.status === 'success') {
                    // Render messages
                    const messagesHtml = data.messages.map(msg => `
                        <div class="message ${msg.is_sender ? 'sent' : 'received'}" style="
                            padding: 10px;
                            margin: 5px;
                            border-radius: 8px;
                            max-width: 70%;
                            ${msg.is_sender ? 'margin-left: auto; background-color: #dcf8c6;' : 'background-color: #fff;'}
                        ">
                            <div style="font-weight: 500;">${msg.sender}</div>
                            <div>${msg.content}</div>
                            <div style="font-size: 0.8em; color: #888; text-align: right;">${msg.timestamp}</div>
                        </div>
                    `).join('');

                    document.getElementById('chatMessages').innerHTML = messagesHtml;

                    // Scroll to bottom of messages
                    const chatMessages = document.getElementById('chatMessages');
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }
            } catch (error) {
                console.error('Error fetching messages:', error);
                document.getElementById('chatMessages').innerHTML = '<div class="error">Error loading messages</div>';
            }
        }

        // Prevent form from regular submission and handle it via AJAX
        document.getElementById('replyForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(this);
            try {
                const response = await fetch(this.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const data = await response.json();
                if (data.status === 'success') {
                    // Clear the textarea
                    this.reset();
                    // Refresh the conversation
                    showConversation(document.getElementById('recipient_id').value);
                }
            } catch (error) {
                console.error('Error sending message:', error);
            }
        });
    </script>
</body>
</html>