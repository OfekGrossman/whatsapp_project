<!DOCTYPE html>
<html lang="en">
<head>
    <title>WhatsApp Web - Login</title>
    {% load static %}
    <link rel="stylesheet" href="{% static 'styles.css' %}">
</head>
<body style="background-color: var(--secondary-color);">
    <div class="app-container" style="justify-content: center; align-items: center; min-height: 100vh;">
        <div class="login-card">
            <div style="text-align: center; margin-bottom: 32px;">
                <h2 style="color: var(--primary-color); font-size: 1.5em;">Login to WhatsApp</h2>
            </div>

            {% if error %}
                <div class="error-message">
                    {{ error }}
                </div>
            {% endif %}

            <form method="post" id="loginForm">
                {% csrf_token %}
                <div class="form-group">
                    <label for="id_username">Username</label>
                    <input
                        type="text"
                        name="username"
                        id="id_username"
                        placeholder="Enter your username"
                        required
                    >
                </div>
                <div class="form-group">
                    <label for="id_password">Password</label>
                    <input
                        type="password"
                        name="password"
                        id="id_password"
                        placeholder="Enter your password"
                        required
                    >
                </div>
                <div class="button-group" style="display: flex; gap: 10px; justify-content: center;">
                    <button type="submit" style="flex: 1;">
                        <span style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                            Login
                        </span>
                    </button>
                    <button type="button" onclick="clearForm()" style="flex: 1; background-color: #6c757d;">
                        <span style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                            Clear
                        </span>
                    </button>
                </div>
            </form>

            <div style="text-align: center; margin-top: 24px;">
                <p style="color: var(--text-secondary);">
                    Don't have an account? <a href="{% url 'register' %}" style="color: var(--primary-color);">Register here</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        function clearForm() {
            document.getElementById('loginForm').reset();
        }
    </script>
</body>
</html>